NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
NEO4J_HTTP_URI=http://localhost:7474

# This is for LLMs.
LLM_TYPE=nvidia # Options: openai, groq, ollama, nvidia
OPENAI_API_KEY=
OLLAMA_API_KEY=
NVIDIA_API_KEY=
GROQ_API_KEY=
NVIDIA_ENDPOINT=
OLLAMA_ENDPOINT=
LLM_TEMPERATURE=
LLM_MODEL_NAME=

## langsmith config
LANGSMITH_API_KEY=your-api-key-here  # Replace with your actual LangSmith API key.
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=your-project-name # Replace 'your-project-name' with the actual project name you want to use.
